{
  "compilerOptions": {
    "target": "ES2020", //tell typescript to convert into js version that node.js understand
    "module": "NodeNext", //to always use ESM js
    "rootDir": "./src", //setup root dir
    "outDir": "./dist", //setup output for translated ts into js
    "esModuleInterop": true,
    "strict": true
  }
}

